        oa:start 70 ;
        oa:end 80 ;
        oa:exact "songwriter"
    ], [
        oa:hasSource source:Mick_Jagger_Wikipedia ;
        oa:start 86 ;
        oa:end 99 ;
        oa:exact "film producer"
    ], [
        oa:hasSource source:Mick_Jagger_Wikipedia ;
        oa:start 113 ;
        oa:end 124 ;
        oa:exact "lead singer"
    ], [
        oa:hasSource source:Mick_Jagger_Wikipedia ;
        oa:start 456 ;
        oa:end 465 ;
        oa:exact "front men"
    ], [
        oa:hasSource source:Mick_Jagger_Wikipedia ;
