source:Mick_Jagger_Wikipedia a prov:Entity ;
    schema:name "Mick Jagger - Wikipedia" ;
    schema:url <https://en.wikipedia.org/wiki/Mick_Jagger> .

extraction:Mick_Jagger_Wikipedia_Mode2 a prov:Activity ;
    rdfs:label "Mode 2 extraction from Mick Jagger Wikipedia article" ;
    prov:used source:Mick_Jagger_Wikipedia .

person:Sir_Michael_Philip_Jagger a musicians:Person ;
    rdfs:label "Sir Michael Philip Jagger" ;
    schema:name "Sir Michael Philip Jagger" ;
    schema:alternateName "Mick Jagger" ;
    schema:birthDate "1943-07-26"^^xsd:date ;
    musicians:hasCareer career:Mick_Jagger_career ;
    musicians:hasDegreeOfFame musicians:InternationalFame ;
    musicians:memberOf band:the_Rolling_Stones ;
    musicians:hasBandMembership membership:Mick_Jagger_the_Rolling_Stones_1962 ;
    musicians:hasRoleInMovie movie:Performance,
        movie:Ned_Kelly ;
    prov:wasGeneratedBy extraction:Mick_Jagger_Wikipedia_Mode2 ;
    prov:wasDerivedFrom [
        oa:hasSource source:Mick_Jagger_Wikipedia ;
        oa:start 0 ;
        oa:end 25 ;
        oa:exact "Sir Michael Philip Jagger"
    ], [
        oa:hasSource source:Mick_Jagger_Wikipedia ;
        oa:start 167 ;
        oa:end 173 ;
        oa:exact "Jagger"
    ] .

