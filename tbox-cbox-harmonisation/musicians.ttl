### General W3C namespaces ###

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix schema: <http://schema.org/> .
@prefix wd:   <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix inst: <http://instruments.knowledge-graph-guys.com/> . ## Fixed from http://instruments.knowledge-graph-guys.com/
@prefix imdb: <https://www.imdb.com/title/> .

### Your group's namespace ###

@prefix musicians: <https://www.knowledge-graph-guys.com/music-ontology/musicians#> .
@prefix data: <https://www.knowledge-graph-guys.com/music-ontology/data#> .

### CLASS DEFINITIONS ###

musicians:MusicianOntology a owl:Ontology ;
    rdfs:comment "This ontology defines concepts related to musicians, their careers, and roles in music."@en ;
    rdfs:label "Musicians Ontology"@en .

musicians:Person a owl:Class ;
    rdfs:subClassOf schema:Person ;
    rdfs:label "Person"@en, "Person"@de ;
    rdfs:comment "An individual human being, typically involved in musical activities."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:MusicalCareer a owl:Class ;
    rdfs:label "Musical Career"@en, "Musikalische Karriere"@de ;
    rdfs:comment "The professional involvement of a person in musical activities."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:MusicalRole a owl:Class ;
    rdfs:label "Musical Role"@en, "Musikale Rolle"@de ;
    rdfs:comment "The role played by a person in musical activities."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:hasCareer a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:MusicalCareer .

musicians:plays a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:label "plays"@en ;
    rdfs:range inst:Instrument . # Fixed class reference from instruments-ontology-v3-school.ttl

musicians:hasPrimaryInstrument a owl:ObjectProperty ;
    rdfs:label "has primary instrument"@en ;
    rdfs:domain musicians:Person ;
    rdfs:range inst:Instrument .

musicians:Language a owl:Class ;
    rdfs:label "Language"@en, "Sprache"@de ;
    rdfs:comment "A system of communication used by a particular community or country."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:speaks a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:Language .

musicians:hasGender a owl:DatatypeProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range xsd:string .

musicians:Movie a owl:Class ;
    rdfs:label "Movie"@en, "Film"@de ;
    rdfs:comment "A motion picture or film."@en ;
    rdfs:subClassOf schema:Movie ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:hasRoleInMovie a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:Movie .

musicians:DegreeOfFame a owl:Class ;
    rdfs:label "Degree of Fame"@en, "Grad der Berühmtheit"@de ;
    rdfs:comment "The level of recognition and popularity a person has achieved in their musical career."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology ;
    owl:oneOf (
        musicians:LocalFame
        musicians:NationalFame
        musicians:InternationalFame
    ) .

musicians:LocalFame a musicians:DegreeOfFame ;
    rdfs:label "Local Fame"@en .

musicians:NationalFame a musicians:DegreeOfFame ;
    rdfs:label "National Fame"@en .

musicians:InternationalFame a musicians:DegreeOfFame ;
    rdfs:label "International Fame"@en .

musicians:hasDegreeOfFame a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:DegreeOfFame .

musicians:hasRole a owl:ObjectProperty ;
    rdfs:domain musicians:MusicalCareer ;
    rdfs:range musicians:MusicalRole .

#### SKOS DEFINITIONS ####

musicians:MusicalRoles a skos:ConceptScheme ;
    skos:prefLabel "Musical Roles"@en, "Musikale Rollen"@de ;
    skos:definition "A person who creates, performs, or is involved in music."@en ;
    skos:exactMatch wd:Q639669 ;
    skos:scopeNote "we used ChatGPT"@en ;
    rdfs:comment "Concept definitions and mappings were developed using information from Wikidata, Wikipedia, and large language models (LLMs), followed by human review and curation."@en ;
    skos:hasTopConcept
        musicians:Singer,
        musicians:Instrumentalist,
        musicians:Songwriter,
        musicians:Melodist,
        musicians:MusicTeacher,
        musicians:MusicProducer .

musicians:Singer a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Singer"@en, "Sänger"@de ;
    skos:definition "A person who performs songs, typically with a focus on vocal ability."@en ;
    skos:exactMatch wd:Q177220 ;
    skos:topConceptOf musicians:MusicalRoles ;
    skos:narrower musicians:PopSinger, musicians:RockSinger, musicians:OperaSinger ;
    skos:scopeNote "Used for persons whose primary musical activity is vocal performance, either as solo artists or members of musical groups."@en .

musicians:PopSinger a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Pop Singer"@en, "Pop-Sänger"@de ;
    skos:definition "A singer who performs pop music."@en ;
    skos:exactMatch wd:Q60723829 ;
    skos:broader musicians:Singer ;
    skos:scopeNote "Used for persons who specialize in performing pop music."@en .

musicians:RockSinger a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Rock Singer"@en, "Rock-Sänger"@de ;
    skos:definition "A singer who performs rock music."@en ;
    skos:exactMatch wd:Q104218554 ;
    skos:broader musicians:Singer ;
    skos:scopeNote "Used for persons who specialize in performing rock music."@en .

musicians:OperaSinger a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Opera Singer"@en, "Opernsänger"@de ;
    skos:definition "A singer who performs opera and classical vocal repertoire."@en ;
    skos:exactMatch wd:Q2865819 ;
    skos:broader musicians:Singer ;
    skos:scopeNote "Used for persons whose primary musical activity is performing opera roles."@en .

musicians:Instrumentalist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Instrumentalist"@en, "Instrumentalist"@de ;
    skos:definition "A person who plays a musical instrument."@en ;
    skos:exactMatch wd:Q1278335 ;
    skos:topConceptOf musicians:MusicalRoles ;
    skos:narrower musicians:Pianist, musicians:Guitarist, musicians:Drummer, musicians:Violinist .

musicians:Pianist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Pianist"@en, "Pianist"@de ;
    skos:definition "A person who plays the piano."@en ;
    skos:exactMatch wd:Q486748 ;
    skos:broader musicians:Instrumentalist .

musicians:Guitarist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Guitarist"@en, "Gitarrist"@de ;
    skos:definition "A person who plays the guitar."@en ;
    skos:exactMatch wd:Q855091 ;
    skos:broader musicians:Instrumentalist .

musicians:Drummer a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Drummer"@en, "Schlagzeuger"@de ;
    skos:definition "A person who plays the drums."@en ;
    skos:exactMatch wd:Q386854 ;
    skos:broader musicians:Instrumentalist .

musicians:Violinist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Violinist"@en, "Geiger"@de ;
    skos:definition "A person who plays the violin."@en ;
    skos:exactMatch wd:Q1259917 ;
    skos:broader musicians:Instrumentalist .

musicians:Songwriter a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Songwriter"@en, "Songwriter"@de ;
    skos:definition "A person who writes songs."@en ;
    skos:exactMatch wd:Q753110 ;
    skos:topConceptOf musicians:MusicalRoles ;
    skos:narrower musicians:Lyricist .

musicians:Lyricist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Lyricist"@en, "Songtexter"@de ;
    skos:definition "A person who writes lyrics for songs."@en ;
    skos:exactMatch wd:Q822146 ;
    skos:broader musicians:Songwriter .

musicians:Melodist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Melodist"@en, "Melodist"@de ;
    skos:definition "A person who writes melodies."@en ;
    skos:exactMatch wd:Q124738259 ;
    skos:topConceptOf musicians:MusicalRoles ;
    skos:narrower musicians:HookMelodist, musicians:VocalMelodist .

musicians:HookMelodist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Hook Melodist"@en, "Hook-Melodist"@de ;
    skos:definition "A person who writes catchy melodies."@en ;
    skos:broader musicians:Melodist .

musicians:VocalMelodist a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Vocal Melodist"@en, "Vocal-Melodist"@de ;
    skos:definition "Writes melodies specifically for singers."@en ;
    skos:broader musicians:Melodist .

musicians:MusicTeacher a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Music Teacher"@en, "Musiklehrer"@de ;
    skos:definition "A person who teaches music."@en ;
    skos:exactMatch wd:Q2675537 ;
    skos:topConceptOf musicians:MusicalRoles ;
    skos:narrower musicians:VocalCoach, musicians:PianoTeacher .

musicians:VocalCoach a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Vocal Coach"@en, "Gesangscoach"@de ;
    skos:definition "A music teacher who trains singers in vocal technique, interpretation, and performance."@en ;
    skos:exactMatch wd:Q20971450 ;
    skos:broader musicians:MusicTeacher .

musicians:PianoTeacher a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Piano Teacher"@en, "Klavierlehrer"@de ;
    skos:definition "A music teacher who teaches students how to play the piano."@en ;
    skos:closeMatch wd:Q17303149 ;
    skos:broader musicians:MusicTeacher .

musicians:MusicProducer a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Music Producer"@en, "Musikproduzent"@de ;
    skos:definition "A person who oversees and manages the creation and production of music recordings."@en ;
    skos:topConceptOf musicians:MusicalRoles ;
    skos:narrower
        musicians:RecordProducer,
        musicians:ExecutiveProducer .

musicians:RecordProducer a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Record Producer"@en, "Tonträgerproduzent"@de ;
    skos:definition "A music producer who supervises and directs the artistic and technical aspects of recording music."@en ;
    skos:exactMatch wd:Q183945 ;
    skos:broader musicians:MusicProducer .

musicians:ExecutiveProducer a skos:Concept, musicians:MusicalRole ;
    skos:prefLabel "Executive Producer"@en, "Executive Producer"@de ;
    skos:definition "A producer responsible for financing, administration, or overall project supervision of music productions."@en ;
    skos:exactMatch wd:Q1053574 ;
    skos:broader musicians:MusicProducer .

# ==========================================
# Language Concept Scheme and Hierarchy (L1, L2, L3)
# ==========================================

musicians:Languages a skos:ConceptScheme ;
    skos:prefLabel "Language"@en ;
    skos:definition "The method of human communication, either spoken or written, consisting of the use of words in a structured and conventional way."@en ;
    skos:hasTopConcept musicians:EuropeanLanguages, musicians:AsianLanguages, musicians:MiddleEasternLanguages, musicians:AfricanLanguages .

# ==========================================
# L1 CONCEPTs (Including skos:narrower to L2)
# ==========================================

musicians:EuropeanLanguages 
    a skos:Concept ;
    skos:prefLabel "European Languages"@en ;
    skos:definition "Major languages originating from Europe, widely used in international business, culture, and education."@en ;
    skos:topConceptOf musicians:Languages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:English, musicians:Spanish, musicians:French, musicians:German, musicians:Portuguese, musicians:Dutch, musicians:Russian .

musicians:AsianLanguages 
    a skos:Concept ;
    skos:prefLabel "Asian Languages"@en ;
    skos:definition "Major languages originating from East, South, and Southeast Asia, representing diverse language families like Sino-Tibetan and Indo-Aryan."@en ;
    skos:topConceptOf musicians:Languages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:Japanese, musicians:MandarinChinese .

musicians:MiddleEasternLanguages 
    a skos:Concept ;
    skos:prefLabel "Middle Eastern Languages"@en ;
    skos:definition "Languages originating from and predominantly spoken in the Middle East, including the Semitic and Iranian language branches."@en ;
    skos:topConceptOf musicians:Languages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:Arabic .

musicians:AfricanLanguages 
    a skos:Concept ;
    skos:prefLabel "African Languages"@en ;
    skos:definition "Languages native to the African continent, spanning major phyla such as Niger-Congo, Afroasiatic, and Nilo-Saharan."@en ;
    skos:topConceptOf musicians:Languages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:Swahili .

# ==========================================
# L2 CONCEPTs (Including skos:narrower to L3)
# ==========================================

musicians:English 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "English"@en ;
    skos:definition "The most widely used international language for business, science, and media."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:AmericanEnglish, musicians:BritishEnglish .

musicians:Spanish 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Spanish"@en ;
    skos:definition "A Romance language originating from the Iberian Peninsula, widely spoken across the Americas and Europe."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:CastilianSpanish, musicians:LatinAmericanSpanish .

musicians:French 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "French"@en ;
    skos:definition "A Romance language originating in France, historically used as a primary language of diplomacy and international relations."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:ParisianFrench, musicians:QuebecFrench .

musicians:German 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "German"@en ;
    skos:definition "A Germanic language spoken primarily in Central Europe, acting as a major language of philosophy, engineering, and commerce."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:HighGerman, musicians:SwissGerman .

musicians:Portuguese 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Portuguese"@en ;
    skos:definition "A Romance language originating from the Western Iberian Peninsula, widespread across South America, Africa, and Europe."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:EuropeanPortuguese, musicians:BrazilianPortuguese .

musicians:Dutch 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Dutch"@en ;
    skos:definition "A West Germanic language spoken primarily in the Netherlands and Belgium, playing a significant role in maritime history and European trade."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:Limburgs, musicians:Flemish, musicians:Afrikaans . 

musicians:Russian 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Russian"@en ;
    skos:definition "An East Slavic language written in the Cyrillic script, serving as a major regional language across Eastern Europe and Northern Asia."@en ;
    skos:broader musicians:EuropeanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:StandardRussian .

musicians:Japanese 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Japanese"@en ;
    skos:definition "An East Asian language spoken primarily in Japan, characterized by a complex system of honorifics and a distinct tripartite writing system."@en ;
    skos:broader musicians:AsianLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:StandardJapanese, musicians:KansaiDialect .

musicians:MandarinChinese 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Mandarin Chinese"@en ;
    skos:definition "A Sinitic language forming the most spoken branch of Chinese, serving as the official national language of China and Taiwan."@en ;
    skos:broader musicians:AsianLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:StandardMandarin, musicians:TaiwaneseMandarin .

musicians:Arabic 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Arabic"@en ;
    skos:definition "A Semitic language originating from the Arabian Peninsula, widely used across the Middle East and North Africa as a liturgical and official language."@en ;
    skos:broader musicians:MiddleEasternLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:ModernStandardArabic, musicians:EgyptianArabic .

musicians:Swahili 
    a skos:Concept, musicians:Language ;
    skos:prefLabel "Swahili"@en ;
    skos:definition "A Bantu lingua franca spoken extensively across East Africa, serving as a vital regional vehicle for trade, administration, and education."@en ;
    skos:broader musicians:AfricanLanguages ;
    skos:inScheme musicians:Languages ;
    skos:narrower musicians:Kiunguja .

# ==========================================
# L3 CONCEPTs (Sub-Languages / Variants)
# ==========================================

# Sub-Languages for English
musicians:AmericanEnglish 
    a skos:Concept ;
    skos:prefLabel "American English"@en ;
    skos:definition "The variety of the English language native to the United States."@en ;
    skos:broader musicians:English ;
    skos:inScheme musicians:Languages .

musicians:BritishEnglish 
    a skos:Concept ;
    skos:prefLabel "British English"@en ;
    skos:definition "The variety of the English language native to the United Kingdom."@en ;
    skos:broader musicians:English ;
    skos:inScheme musicians:Languages .

# Sub-Languages for Spanish
musicians:CastilianSpanish 
    a skos:Concept;
    skos:prefLabel "Castilian Spanish"@en ;
    skos:definition "The variety of the Spanish language spoken in northern and central Spain, often considered the standard form."@en ;
    skos:broader musicians:Spanish ;
    skos:inScheme musicians:Languages .

musicians:LatinAmericanSpanish 
    a skos:Concept ;
    skos:prefLabel "Latin American Spanish"@en ;
    skos:definition "The regional variants of the Spanish language spoken in the countries of Hispanic America."@en ;
    skos:broader musicians:Spanish ;
    skos:inScheme musicians:Languages .

# Sub-Languages for French
musicians:ParisianFrench 
    a skos:Concept ;
    skos:prefLabel "Parisian French"@en ;
    skos:definition "The standard variety of the French language spoken in and around Paris."@en ;
    skos:broader musicians:French ;
    skos:inScheme musicians:Languages .

musicians:QuebecFrench 
    a skos:Concept ;
    skos:prefLabel "Quebec French"@en ;
    skos:definition "The dominant variety of the French language spoken in Canada."@en ;
    skos:broader musicians:French ;
    skos:inScheme musicians:Languages .

# Sub-Languages for German
musicians:HighGerman 
    a skos:Concept ;
    skos:prefLabel "High German"@en ;
    skos:definition "The standard variety of the German language used in education, literature, and public communication."@en ;
    skos:broader musicians:German ;
    skos:inScheme musicians:Languages .

musicians:SwissGerman 
    a skos:Concept ;
    skos:prefLabel "Swiss German"@en ;
    skos:definition "The Alemannic dialects spoken in the German-speaking parts of Switzerland."@en ;
    skos:broader musicians:German ;
    skos:inScheme musicians:Languages .

# Sub-Languages for Portuguese
musicians:EuropeanPortuguese 
    a skos:Concept ;
    skos:prefLabel "European Portuguese"@en ;
    skos:definition "The variety of the Portuguese language spoken in Portugal."@en ;
    skos:broader musicians:Portuguese ;
    skos:inScheme musicians:Languages .

musicians:BrazilianPortuguese 
    a skos:Concept ;
    skos:prefLabel "Brazilian Portuguese"@en ;
    skos:definition "The variety of the Portuguese language spoken in Brazil."@en ;
    skos:broader musicians:Portuguese ;
    skos:inScheme musicians:Languages .

# Sub-Languages for Dutch
musicians:Limburgs 
    a skos:Concept ;
    skos:prefLabel "Limburgs"@en ;
    skos:definition "The standard variety of the Dutch language as spoken in the Province of Limburg."@en ;
    skos:broader musicians:Dutch ;
    skos:inScheme musicians:Languages .

musicians:Flemish 
    a skos:Concept ;
    skos:prefLabel "Flemish"@en ;
    skos:definition "The regional variety of the Dutch language spoken in Flanders, Belgium."@en ;
    skos:broader musicians:Dutch ;
    skos:inScheme musicians:Languages .

musicians:Afrikaans 
    a skos:Concept ;
    skos:prefLabel "Afrikaans"@en ;
    skos:definition "A daughter language of Dutch that developed in South Africa from 17th-century Early Modern Dutch dialects brought by European settlers."@en ;
    skos:broader musicians:Dutch ;
    skos:inScheme musicians:Languages .


# Sub-Languages for Russian
musicians:StandardRussian 
    a skos:Concept ;
    skos:prefLabel "Standard Russian"@en ;
    skos:definition "The modern literary and official variant of the Russian language."@en ;
    skos:broader musicians:Russian ;
    skos:inScheme musicians:Languages .

# Sub-Languages for Japanese
musicians:StandardJapanese 
    a skos:Concept ;
    skos:prefLabel "Standard Japanese"@en ;
    skos:definition "The official and literary form of the Japanese language, based largely on the historical dialect spoken in Tokyo."@en ;
    skos:broader musicians:Japanese ;
    skos:inScheme musicians:Languages .

musicians:KansaiDialect 
    a skos:Concept ;
    skos:prefLabel "Kansai Dialect"@en ;
    skos:definition "A prominent regional group of Japanese dialects spoken in the Kansai region, including Osaka, Kyoto, and Kobe."@en ;
    skos:broader musicians:Japanese ;
    skos:inScheme musicians:Languages .

# Sub-talen voor Mandarijn
musicians:StandardMandarin 
    a skos:Concept ;
    skos:prefLabel "Standard Mandarin"@en ;
    skos:definition "The official standardized language of mainland China, structured around the phonology of the Beijing dialect."@en ;
    skos:broader musicians:MandarinChinese ;
    skos:inScheme musicians:Languages .

musicians:TaiwaneseMandarin 
    a skos:Concept ;
    skos:prefLabel "Taiwanese Mandarin"@en ;
    skos:definition "The official variant of Mandarin Chinese spoken and written in Taiwan, showing distinct lexical and phonological features."@en ;
    skos:broader musicians:MandarinChinese ;
    skos:inScheme musicians:Languages .

# Sub-Languages for Arabic
musicians:ModernStandardArabic 
    a skos:Concept ;
    skos:prefLabel "Modern Standard Arabic"@en ;
    skos:definition "The standardized literary variety of Arabic used throughout the Arab world in writing, formal speech, and broadcasting."@en ;
    skos:broader musicians:Arabic ;
    skos:inScheme musicians:Languages .

musicians:EgyptianArabic 
    a skos:Concept ;
    skos:prefLabel "Egyptian Arabic"@en ;
    skos:definition "The vernacular spoken variety of Arabic native to Egypt, widely understood across the Arab world due to media and cinema influence."@en ;
    skos:broader musicians:Arabic ;
    skos:inScheme musicians:Languages .

# Sub-Language for Swahili
musicians:Kiunguja 
    a skos:Concept ;
    skos:prefLabel "Kiunguja"@en ;
    skos:definition "The specific dialect of Swahili spoken in Zanzibar Town, which serves as the principal foundation for Modern Standard Swahili."@en ;
    skos:broader musicians:Swahili ;
    skos:inScheme musicians:Languages .



# ==========================================
# DATA-GRAPH
# ==========================================

data:paul-mccartney a musicians:Person ;
    musicians:hasCareer data:paul-mccartney-career ;
    schema:givenName "Paul" ;
    schema:familyName "McCartney" ;
    schema:birthDate "1942-06-18"^^xsd:date ;
    musicians:plays inst:bass-guitar ; # URI
    musicians:hasPrimaryInstrument inst:bass-guitar ; # URI
    musicians:speaks musicians:English ;
    musicians:hasDegreeOfFame musicians:InternationalFame ;
    schema:gender "Male" ;
    musicians:hasRoleInMovie data:paul-mccartney-role-in-the-beatles-movie ;
    musicians:hasRoleInMovie data:paul-mccartney-role-in-the-beatles-better-movie .

data:paul-mccartney-career a musicians:MusicalCareer ;
    musicians:hasRole musicians:RockSinger .

data:paul-mccartney-role-in-the-beatles-movie a musicians:Movie ;
    rdfs:label "Yellow Submarine"@en ;
    schema:sameAs imdb:tt0063823 ;
    rdfs:comment "A 1968 animated film featuring the music of The Beatles."@en .

data:paul-mccartney-role-in-the-beatles-better-movie a musicians:Movie ;
    rdfs:label "A Hard Days Night"@en ;
    schema:sameAs imdb:tt0058182 ;
    rdfs:comment "A 1964 film featuring the music of The Beatles."@en .

data:taylor-swift a musicians:Person ;
