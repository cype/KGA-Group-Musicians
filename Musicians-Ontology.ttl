@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix musicians: <https://www.knowledge-graph-guys.com/music-ontology/musicians#> .
@prefix schema: <http://schema.org/> .

musicians:MusicianOntology a owl:Ontology ;
    rdfs:comment "This ontology defines concepts related to musicians, their careers, and roles in music."@en ;
    rdfs:label "Musicians Ontology"@en .

musicians:Person a owl:Class ;
    rdfs:subClassOf schema:Person ;
    rdfs:label "Person"@en, "Person"@de ;
    rdfs:comment "An individual human being, typically involved in musical activities."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:MusicalCareer a owl:Class ;
    rdfs:label "Musical Career"@en, "Musikalische Karriere"@de ;
    rdfs:comment "The professional involvement of a person in musical activities."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:MusicalRole a owl:Class ;
    rdfs:label "Musical Role"@en, "Musikale Rolle"@de ;
    rdfs:comment "The role played by a person in musical activities."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:hasCareer a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:MusicalCareer .

musicians:plays a owl:ObjectProperty ;
    rdfs:domain musicians:Person .
    # rdfs:range instruments:Instrument . # we dont really know, group Instruments

musicians:Language a owl:Class ;
    rdfs:label "Language"@en, "Sprache"@de ;
    rdfs:comment "A system of communication used by a particular community or country."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:speaks a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:Language .

musicians:hasName a owl:DatatypeProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range xsd:string .

musicians:hasGender a owl:DatatypeProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range schema:Gender .

musicians:Movie a owl:Class ;
    rdfs:label "Movie"@en, "Film"@de ;
    rdfs:comment "A motion picture or film."@en ;
    rdfs:subClassOf schema:Movie ;
    rdfs:isDefinedBy musicians:MusicianOntology .

musicians:hasRoleInMovie a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:Movie .

musicians:DegreeOfFame a owl:Class ;
    rdfs:label "Degree of Fame"@en, "Grad der Berühmtheit"@de ;
    rdfs:comment "The level of recognition and popularity a person has achieved in their musical career."@en ;
    rdfs:isDefinedBy musicians:MusicianOntology ;
    owl:oneOf (
        musicians:LocalFame
        musicians:NationalFame
        musicians:InternationalFame
    ) .

musicians:LocalFame a musicians:DegreeOfFame ;
    rdfs:label "Local Fame"@en .

musicians:NationalFame a musicians:DegreeOfFame ;
    rdfs:label "National Fame"@en .

musicians:InternationalFame a musicians:DegreeOfFame ;
    rdfs:label "International Fame"@en .

musicians:hasDegreeOfFame a owl:ObjectProperty ;
    rdfs:domain musicians:Person ;
    rdfs:range musicians:DegreeOfFame .