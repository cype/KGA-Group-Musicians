    skos:definition "A modern hip hop style featuring heavy bass, hi-hats, and atmospheric beats."@en ;
    skos:broader musicians:HipHop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Jazz a skos:Concept ;
