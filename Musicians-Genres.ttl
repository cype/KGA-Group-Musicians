@prefix musicians: <https://www.knowledge-graph-guys.com/music-ontology/musicians#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix wd:   <http://www.wikidata.org/entity/> .

# will be linked to musical career

musicians:MusicGenre a skos:ConceptScheme ;
    skos:prefLabel "Music Genres"@en ;
    skos:definition "A controlled vocabulary of musical genres and subgenres."@en ;
    skos:scopeNote "we used ChatGPT"@en ;
    skos:hasTopConcept
        musicians:Pop,
        musicians:Rock,
        musicians:HipHop,
        musicians:Jazz,
        musicians:Blues,
        musicians:Classical,
        musicians:Country,
        musicians:Reggae,
        musicians:Metal,
        musicians:Folk .

musicians:Pop a skos:Concept ;
    skos:prefLabel "Pop"@en ;
    skos:definition "Catchy, mainstream music focused on strong melodies and broad appeal."@en ;
    skos:exactMatch wd:Q37073 ;
    skos:topConceptOf musicians:MusicGenre ;
    skos:narrower musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Synthpop a skos:Concept ;
    skos:prefLabel "Synthpop"@en ;
    skos:definition "Pop music heavily influenced by synthesizers and electronic sounds."@en ;
    skos:broader musicians:Pop ;
    skos:narrower
        musicians:NewWaveSynthpop,
        musicians:DarkSynthpop,
        musicians:Electropop,
        musicians:Futurepop,
        musicians:MinimalSynth,
        musicians:Coldwave,
        musicians:Synthwave,
        musicians:IndustrialSynthpop,
        musicians:DreamPopSynth,
        musicians:DancePopSynth ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:NewWaveSynthpop a skos:Concept ;
    skos:prefLabel "New Wave Synthpop"@en ;
    skos:definition "Combines synth-driven melodies with the energy and style of new wave music."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:DarkSynthpop a skos:Concept ;
    skos:prefLabel "Dark Synthpop"@en ;
    skos:definition "Features darker themes, atmospheric sounds, and melancholic melodies."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Electropop a skos:Concept ;
    skos:prefLabel "Electropop"@en ;
    skos:definition "A polished, dance-oriented style that emphasizes catchy electronic hooks."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Futurepop a skos:Concept ;
    skos:prefLabel "Futurepop"@en ;
    skos:definition "Blends synthpop with trance and EBM influences, creating an uplifting electronic sound."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:MinimalSynth a skos:Concept ;
    skos:prefLabel "Minimal Synth"@en ;
    skos:definition "Uses stripped-down arrangements, vintage synthesizers, and minimalist production."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Coldwave a skos:Concept ;
    skos:prefLabel "Coldwave"@en ;
    skos:definition "A moody and atmospheric European style characterized by cold, detached vocals and synth textures."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Synthwave a skos:Concept ;
    skos:prefLabel "Synthwave"@en ;
    skos:definition "Inspired by 1980s synthpop, film soundtracks, and retro-futuristic aesthetics."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:IndustrialSynthpop a skos:Concept ;
    skos:prefLabel "Industrial Synthpop"@en ;
    skos:definition "Combines melodic synthpop structures with harsher industrial sounds and rhythms."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:DreamPopSynth a skos:Concept ;
    skos:prefLabel "Dream Pop Synth"@en ;
    skos:definition "Mixes synthpop elements with ethereal vocals and lush, dreamy soundscapes."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:DancePopSynth a skos:Concept ;
    skos:prefLabel "Dance-Pop Synth"@en ;
    skos:definition "Focuses on upbeat rhythms, accessible melodies, and club-friendly production."@en ;
    skos:broader musicians:Synthpop ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Rock a skos:Concept ;
    skos:prefLabel "Rock"@en ;
    skos:definition "Guitar-driven music known for its energy, rhythm, and diverse styles."@en ;
    skos:exactMatch wd:Q11399 ;
    skos:topConceptOf musicians:MusicGenre ;
    skos:narrower musicians:AlternativeRock ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:AlternativeRock a skos:Concept ;
    skos:prefLabel "Alternative Rock"@en ;
    skos:definition "Rock music that explores experimental and non-mainstream approaches."@en ;
    skos:broader musicians:Rock ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:HipHop a skos:Concept ;
    skos:prefLabel "Hip Hop"@en ;
    skos:definition "A genre centered on rap vocals, beats, rhythm, and lyrical expression."@en ;
    skos:exactMatch wd:Q11401 ;
    skos:topConceptOf musicians:MusicGenre ;
    skos:narrower musicians:Trap ;
    skos:scopeNote "we used ChatGPT"@en .

musicians:Trap a skos:Concept ;
